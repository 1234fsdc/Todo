page {
  background-color: var(--bg, #F8FAFC);
  color: var(--text, #0F172A);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

.container {
  --bg: #F8FAFC;
  --surface: #FFFFFF;
  --text: #0F172A;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --text-inverse: #FFFFFF;
  --border: #E2E8F0;
  --primary: #2563EB;
  --primary-dark: #1D4ED8;
  --primary-subtle: #EFF6FF;
  --success: #10B981;
  --success-subtle: #ECFDF5;
  --warning: #F59E0B;
  --warning-subtle: #FFFBEB;
  --error: #EF4444;
  --error-subtle: #FEF2F2;
  --info: #3B82F6;
  --info-subtle: #EFF6FF;
  --shadow-xs: 0 1rpx 2rpx rgba(15, 23, 42, 0.04);
  --shadow-sm: 0 2rpx 6rpx rgba(15, 23, 42, 0.06);
  --shadow-md: 0 6rpx 16rpx rgba(15, 23, 42, 0.08);
  --shadow-lg: 0 12rpx 28rpx rgba(15, 23, 42, 0.10);
  --radius-sm: 12rpx;
  --radius: 16rpx;
  --radius-lg: 20rpx;
  --radius-full: 9999rpx;
  --space-1: 4rpx;
  --space-2: 8rpx;
  --space-3: 12rpx;
  --space-4: 16rpx;
  --space-5: 24rpx;
  --space-6: 32rpx;
  --space-7: 48rpx;
  --space-8: 64rpx;
  --space-10: 80rpx;
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background-color: var(--bg);
}

.container.dark-mode {
  --bg: #0B1120;
  --surface: #111827;
  --text: #F1F5F9;
  --text-secondary: #CBD5E1;
  --text-tertiary: #94A3B8;
  --text-inverse: #0F172A;
  --border: #1E293B;
  --primary: #60A5FA;
  --primary-dark: #3B82F6;
  --primary-subtle: rgba(96, 165, 250, 0.12);
  --success: #34D399;
  --success-subtle: rgba(52, 211, 153, 0.12);
  --warning: #FBBF24;
  --warning-subtle: rgba(251, 191, 36, 0.12);
  --error: #F87171;
  --error-subtle: rgba(248, 113, 113, 0.12);
  --info: #93C5FD;
  --info-subtle: rgba(147, 197, 253, 0.12);
  --shadow-xs: 0 1rpx 2rpx rgba(0, 0, 0, 0.24);
  --shadow-sm: 0 2rpx 6rpx rgba(0, 0, 0, 0.28);
  --shadow-md: 0 6rpx 16rpx rgba(0, 0, 0, 0.32);
  --shadow-lg: 0 12rpx 28rpx rgba(0, 0, 0, 0.36);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-5);
  padding: var(--space-2) 0;
}

.card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
