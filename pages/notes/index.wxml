<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 页面标题栏 -->
  <view class="page-header">
    <view class="header-title-group">
      <text class="page-title">我的笔记</text>
      <text class="page-subtitle">{{notes.length}} 条笔记</text>
    </view>
    <view class="add-btn" bindtap="addNote">
      <text class="add-icon">+</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索标题或内容..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="*this"
          class="category-item {{currentCategory === item ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 笔记列表 -->
  <view class="notes-list" wx:if="{{notes.length > 0}}">
    <view 
      wx:for="{{notes}}" 
      wx:key="id"
      class="note-card {{item.isPinned ? 'pinned' : ''}}"
      style="animation-delay: {{index * 0.05}}s"
      bindtap="editNote"
      data-id="{{item.id}}"
    >
      <view class="note-header">
        <text class="note-title">{{item.title}}</text>
        <view class="pin-btn {{item.isPinned ? 'active' : ''}}" catchtap="togglePin" data-id="{{item.id}}">
          <text class="pin-icon">📌</text>
        </view>
      </view>
      <text class="note-content">{{item.content}}</text>
      <view class="note-footer">
        <text class="note-category">{{item.category}}</text>
        <text class="note-time">{{item.formattedTime}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{notes.length === 0}}">
    <text class="empty-icon">📝</text>
    <text class="empty-title">暂无笔记</text>
  </view>
</view>
