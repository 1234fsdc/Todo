.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding: 8rpx 0;
}

.toolbar-left {
  flex: 1;
}

.back-btn {
  font-size: 28rpx;
  color: #64748B;
  font-weight: 500;
  padding: 8rpx 12rpx;
}

.toolbar-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.pin-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  background: #FFFFFF;
  border: 1rpx solid #E2E8F0;
  font-size: 26rpx;
  color: #64748B;
}

.pin-toggle.active {
  background: #EFF6FF;
  border-color: #3B82F6;
  color: #3B82F6;
}

.pin-icon {
  font-size: 24rpx;
}

.save-btn {
  background: #3B82F6;
  color: #FFFFFF;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* AI 智能分析区域 */
.ai-section {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E2E8F0;
  opacity: 0;
  transform: translateY(-16rpx);
  transition: all 0.3s ease;
  display: none;
}

.ai-section.show {
  opacity: 1;
  transform: translateY(0);
  display: block;
  animation: fadeInUp 0.3s ease-out;
}

.ai-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.ai-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ai-icon {
  font-size: 26rpx;
}

.ai-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3B82F6;
}

.ai-loading {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.loading-icon {
  font-size: 24rpx;
  animation: spin 1s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #94A3B8;
}

.ai-content-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ai-error {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: 8rpx;
}

.error-icon {
  font-size: 28rpx;
}

.error-text {
  font-size: 26rpx;
  color: #DC2626;
  line-height: 1.5;
  flex: 1;
}

.ai-summary {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ai-label {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.ai-content {
  font-size: 26rpx;
  color: #64748B;
  line-height: 1.6;
  background: #F8FAFC;
  padding: 12rpx;
  border-radius: 6rpx;
}

.ai-recommend {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ai-category-recommend {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.ai-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.ai-tag.work {
  background: #EFF6FF;
  color: #3B82F6;
}

.ai-tag.life {
  background: #ECFDF5;
  color: #10B981;
}

.ai-tag.study {
  background: #FFFBEB;
  color: #F59E0B;
}

.ai-tag:active {
  opacity: 0.8;
}

.ai-apply {
  font-size: 22rpx;
  opacity: 0.7;
  font-weight: normal;
}

.ai-keywords {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.ai-keyword-list {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.ai-keyword-tag {
  background: #F8FAFC;
  color: #64748B;
  padding: 4rpx 8rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  border: 1rpx solid #E2E8F0;
}

/* AI 修饰区域 */
.ai-polish-section {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E2E8F0;
}

.polish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #EFF6FF;
  border-radius: 8rpx;
  border: 1rpx solid #3B82F6;
}

.polish-btn:active {
  background: #DBEAFE;
}

.polish-icon {
  font-size: 24rpx;
}

.polish-text {
  font-size: 26rpx;
  color: #3B82F6;
  font-weight: 500;
}

/* 修饰结果 */
.polish-result {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E2E8F0;
}

.polish-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.polish-content {
  font-size: 28rpx;
  color: #0F172A;
  line-height: 1.6;
  background: #F8FAFC;
  padding: 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid #E2E8F0;
}

.polish-actions {
  display: flex;
  gap: 16rpx;
  justify-content: flex-end;
}

.polish-action-btn {
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.polish-action-btn.cancel {
  background: #F8FAFC;
  color: #64748B;
  border: 1rpx solid #E2E8F0;
}

.polish-action-btn.apply {
  background: #3B82F6;
  color: #FFFFFF;
}

.category-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 8rpx 0;
}

.section-label {
  font-size: 28rpx;
  color: #64748B;
  flex-shrink: 0;
  font-weight: 500;
}

.category-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #FFFFFF;
  border-radius: 6rpx;
  border: 1rpx solid #E2E8F0;
  font-size: 28rpx;
  color: #0F172A;
}

.picker-arrow {
  font-size: 18rpx;
  color: #94A3B8;
  margin-left: 8rpx;
}

.title-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: 600;
  color: #0F172A;
  background: transparent;
  border: none;
  border-bottom: 1rpx solid #E2E8F0;
  padding: 12rpx 0;
  margin-bottom: 24rpx;
}

.title-input::placeholder {
  color: #94A3B8;
}

.content-input {
  width: 100%;
  min-height: 400rpx;
  font-size: 30rpx;
  color: #0F172A;
  background: transparent;
  border: none;
  line-height: 1.8;
  padding: 8rpx 0;
}

.content-input::placeholder {
  color: #94A3B8;
}

.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 80rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E2E8F0;
}

.update-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.delete-btn {
  font-size: 26rpx;
  color: #EF4444;
  padding: 8rpx 12rpx;
  font-weight: 500;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(-16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
