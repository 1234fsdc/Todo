<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 页面标题栏 -->
  <view class="page-header">
    <view class="header-title-group">
      <view class="title-row">
        <text class="title-icon">✨</text>
        <text class="page-title">AI 代写</text>
      </view>
      <text class="page-subtitle">描述需求，自动生成笔记或待办</text>
    </view>
    <view class="header-action" bindtap="toggleHistory">
      <text class="action-icon">🕐</text>
    </view>
  </view>

  <!-- 类型切换 -->
  <view class="type-section">
    <view class="type-list">
      <view 
        class="type-item {{generateType === 'todo' ? 'active' : ''}}"
        bindtap="switchType"
        data-type="todo"
      >
        <text class="type-icon">📋</text>
        <text class="type-text">生成待办</text>
      </view>
      <view 
        class="type-item {{generateType === 'note' ? 'active' : ''}}"
        bindtap="switchType"
        data-type="note"
      >
        <text class="type-icon">📝</text>
        <text class="type-text">生成笔记</text>
      </view>
    </view>
  </view>

  <!-- 输入区域 -->
  <view class="input-section">
    <text class="input-label">描述你的需求</text>
    <textarea 
      class="ai-input" 
      placeholder="{{generateType === 'note' ? '例如：帮我整理一份项目复盘笔记，包含问题分析和改进建议...' : '例如：帮我生成本周工作计划，包含会议、代码评审和文档整理...'}}"
      value="{{prompt}}"
      bindinput="onPromptInput"
      maxlength="2000"
      auto-height
    />
  </view>

  <!-- 生成按钮 -->
  <view class="generate-btn {{prompt.trim() ? 'active' : ''}} {{isGenerating ? 'generating' : ''}}" bindtap="generateContent">
    <view wx:if="{{isGenerating}}" class="loading">
      <text class="loading-icon">✨</text>
      <text>生成中...</text>
    </view>
    <view wx:else class="btn-content">
      <text class="btn-icon">✨</text>
      <text>立即生成</text>
    </view>
  </view>

  <!-- 生成结果 -->
  <view class="result-section {{showResult ? 'show' : ''}}">
    <view class="result-header">
      <text class="result-title">生成结果</text>
      <view class="result-actions">
        <text class="action-btn" bindtap="copyResult">复制</text>
        <text class="action-btn" bindtap="regenerate">重新生成</text>
      </view>
    </view>
    
    <view class="result-content">
      <view class="result-field">
        <text class="field-label">标题</text>
        <input 
          class="field-input" 
          value="{{generatedTitle}}"
          bindinput="onTitleInput"
          placeholder="输入标题..."
        />
      </view>
      
      <view class="result-field">
        <text class="field-label">内容</text>
        <textarea 
          class="field-textarea" 
          value="{{generatedContent}}"
          bindinput="onContentInput"
          placeholder="输入内容..."
          maxlength="5000"
          auto-height
        />
      </view>
      
      <view class="result-field">
        <text class="field-label">分类</text>
        <view class="category-tags">
          <view 
            wx:for="{{categories}}" 
            wx:key="*this"
            wx:if="{{item !== '全部'}}"
            class="category-tag {{generatedCategory === item ? 'active' : ''}}"
            bindtap="selectCategory"
            data-category="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>
      
      <view class="result-field" wx:if="{{generateType === 'note'}}">
        <text class="field-label">选项</text>
        <view class="pin-toggle {{isPinned ? 'active' : ''}}" bindtap="togglePin">
          <text class="pin-icon">📌</text>
          <text>置顶</text>
        </view>
      </view>
    </view>
    
    <view class="save-btn" bindtap="saveResult">
      <text>保存{{generateType === 'note' ? '笔记' : '待办'}}</text>
    </view>
  </view>

  <!-- 历史记录弹窗 -->
  <view class="history-modal {{showHistory ? 'show' : ''}}" bindtap="closeHistory">
    <view class="history-panel" catchtap="preventClose">
      <view class="history-header">
        <text class="history-title">历史记录</text>
        <text class="history-close" bindtap="closeHistory">✕</text>
      </view>
      <scroll-view class="history-scroll" scroll-y>
        <view class="history-list" wx:if="{{history.length > 0}}">
          <view 
            wx:for="{{history}}" 
            wx:key="id"
            class="history-item"
            bindtap="useHistory"
            data-index="{{index}}"
          >
            <text class="history-type">{{item.type === 'note' ? '📝' : '📋'}}</text>
            <view class="history-content">
              <text class="history-title">{{item.title}}</text>
              <text class="history-time">{{item.time}}</text>
            </view>
          </view>
        </view>
        <view class="history-empty" wx:if="{{history.length === 0}}">
          <text>暂无历史记录</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
