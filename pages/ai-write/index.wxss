.page-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--space-6);
  padding: var(--space-2) 0 var(--space-5);
  border-bottom: 1rpx solid var(--border);
}

.header-title-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.header-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--surface);
  border: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 32rpx;
}

.type-section {
  margin-bottom: var(--space-5);
}

.type-list {
  display: flex;
  gap: 16rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 12rpx;
  border: 1rpx solid var(--border);
}

.type-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  border-radius: var(--radius-sm);
  transition: all 0.15s ease;
}

.type-item.active {
  background: var(--primary);
}

.type-item.active .type-icon,
.type-item.active .type-text {
  color: var(--text-inverse);
}

.type-icon {
  font-size: 32rpx;
}

.type-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
}

.input-section {
  margin-bottom: var(--space-5);
}

.input-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.ai-input {
  width: 100%;
  min-height: 200rpx;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.ai-input::placeholder {
  color: var(--text-tertiary);
}

.generate-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: var(--border);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-5);
  gap: 12rpx;
}

.generate-btn.active {
  background: var(--primary);
}

.generate-btn.generating {
  background: var(--primary);
  opacity: 0.8;
}

.generate-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-tertiary);
}

.generate-btn.active text,
.generate-btn.generating text {
  color: var(--text-inverse);
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 28rpx;
}

.loading {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-icon {
  font-size: 28rpx;
  animation: spin 1s linear infinite;
}

.result-section {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: var(--space-5);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-sm);
  opacity: 0;
  transform: translateY(16rpx);
  transition: all 0.3s ease;
  display: none;
}

.result-section.show {
  opacity: 1;
  transform: translateY(0);
  display: block;
  animation: fadeInUp 0.3s ease-out;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.result-actions .action-btn {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
  padding: 4rpx 8rpx;
}

.result-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.field-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.field-input {
  width: 100%;
  height: 76rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  color: var(--text);
  font-size: 28rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.field-textarea {
  width: 100%;
  min-height: 160rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 24rpx;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.6;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
}

.category-tags {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.category-tag {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--bg);
  color: var(--text-secondary);
  font-size: 26rpx;
  border: 1rpx solid var(--border);
  font-weight: 500;
}

.category-tag.active {
  background: var(--primary);
  color: var(--text-inverse);
  border-color: var(--primary);
}

.pin-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  background: var(--bg);
  border: 1rpx solid var(--border);
  width: fit-content;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.pin-toggle.active {
  background: var(--primary-subtle);
  border-color: var(--primary);
  color: var(--primary);
}

.pin-icon {
  font-size: 24rpx;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: var(--primary);
  border-radius: var(--radius-lg);
  margin-top: 24rpx;
}

.save-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-inverse);
}

.history-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  display: flex;
  align-items: flex-end;
}

.history-modal.show {
  opacity: 1;
  visibility: visible;
}

.history-panel {
  width: 100%;
  background: var(--surface);
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  max-height: 70vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.history-modal.show .history-panel {
  transform: translateY(0);
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.history-close {
  font-size: 32rpx;
  color: var(--text-tertiary);
  padding: 8rpx;
}

.history-scroll {
  max-height: 50vh;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
}

.history-type {
  font-size: 32rpx;
  width: 44rpx;
  text-align: center;
  flex-shrink: 0;
}

.history-content {
  flex: 1;
  min-width: 0;
}

.history-item .history-title {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 4rpx;
}

.history-empty {
  text-align: center;
  padding: 64rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
