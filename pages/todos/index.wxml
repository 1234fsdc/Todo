<view class="container {{darkMode ? 'dark-mode' : ''}}">
  <!-- 页面标题栏 -->
  <view class="page-header">
    <view class="header-title-group">
      <text class="page-title">待办事项</text>
      <text class="page-subtitle">{{stats.pending}} 待完成</text>
    </view>
    <view class="header-action">
      <text class="action-icon">📋</text>
    </view>
  </view>

  <!-- 统计栏 -->
  <view class="stats-bar">
    <view class="stat-item">
      <text class="stat-number pending">{{stats.pending}}</text>
      <text class="stat-label">待办</text>
    </view>
    <view class="stat-item">
      <text class="stat-number completed">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-item">
      <text class="stat-number total">{{stats.total}}</text>
      <text class="stat-label">总计</text>
    </view>
  </view>

  <!-- AI 智能建议 -->
  <view class="ai-suggestion-section {{showAISuggestion ? 'show' : ''}}" wx:if="{{showAISuggestion}}">
    <view class="ai-suggestion-card">
      <view class="ai-suggestion-header">
        <text class="ai-suggestion-icon">✨</text>
        <text class="ai-suggestion-title">AI 智能建议</text>
      </view>
      <text class="ai-suggestion-text">{{aiSuggestion}}</text>
    </view>
    <view class="ai-sort-toggle {{useSmartSort ? 'active' : ''}}" bindtap="toggleSmartSort">
      <text class="ai-sort-icon">🧠</text>
      <text class="ai-sort-text">{{useSmartSort ? '智能排序中' : '开启智能排序'}}</text>
    </view>
  </view>

  <!-- 快速添加 -->
  <view class="quick-add-section">
    <view class="quick-add-row">
      <view class="quick-input-wrap">
        <text class="quick-plus">+</text>
        <input 
          class="quick-input" 
          placeholder="快速添加待办..."
          value="{{newTodoTitle}}"
          bindinput="onInputChange"
          confirm-type="done"
          bindconfirm="addTodo"
        />
      </view>
      <view class="quick-add-btn {{newTodoTitle.trim() ? 'active' : ''}}" bindtap="addTodo">
        <text>添加</text>
      </view>
    </view>
    <view class="quick-category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="*this"
        wx:if="{{item !== '全部'}}"
        class="quick-category-item {{newTodoCategory === item ? 'active' : ''}}"
        bindtap="selectQuickCategory"
        data-category="{{item}}"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 分类筛选 -->
  <view class="category-section">
    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view 
          wx:for="{{categories}}" 
          wx:key="*this"
          class="category-item {{currentCategory === item ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-category="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
    <view class="category-action-btn" bindtap="deleteCompleted" wx:if="{{stats.completed > 0}}">
      <text>🗑️</text>
      <text class="category-action-text">删除</text>
    </view>
  </view>

  <!-- 待办列表 -->
  <view class="todos-list" wx:if="{{todos.length > 0}}">
    <view 
      wx:for="{{todos}}" 
      wx:key="id"
      class="todo-item {{item.completed ? 'completed' : ''}} {{item.isPinned ? 'pinned' : ''}}"
      style="animation-delay: {{index * 0.05}}s"
    >
      <view class="todo-check" bindtap="toggleComplete" data-id="{{item.id}}">
        <view class="check-circle {{item.completed ? 'checked' : ''}}">
          <text wx:if="{{item.completed}}">✓</text>
        </view>
      </view>
      
      <view class="todo-content" bindtap="toggleComplete" data-id="{{item.id}}">
        <view class="todo-title-row">
          <text class="todo-title">{{item.title}}</text>
          <text class="todo-category-tag" wx:if="{{item.category && item.category !== '全部'}}">{{item.category}}</text>
        </view>
      </view>

      <view class="todo-actions">
        <view class="action-btn pin-btn {{item.isPinned ? 'active' : ''}}" bindtap="togglePin" data-id="{{item.id}}">
          <text>📌</text>
        </view>
        <view class="action-btn delete-btn" bindtap="deleteTodo" data-id="{{item.id}}">
          <text>🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{todos.length === 0}}">
    <text class="empty-icon">🎉</text>
    <text class="empty-title">暂无待办</text>
  </view>
</view>
