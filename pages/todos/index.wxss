.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--space-6);
  padding: var(--space-2) 0 var(--space-5);
  border-bottom: 1rpx solid var(--border);
}

.header-title-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  line-height: 1.2;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.header-action {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--primary-subtle);
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon {
  font-size: 32rpx;
}

.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  margin-bottom: var(--space-5);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}

/* AI 智能建议 */
.ai-suggestion-section {
  margin-bottom: var(--space-5);
  opacity: 0;
  transform: translateY(-20rpx);
  transition: all 0.4s ease;
  display: none;
}

.ai-suggestion-section.show {
  opacity: 1;
  transform: translateY(0);
  display: block;
  animation: fadeInUp 0.4s ease-out;
}

.ai-suggestion-card {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  margin-bottom: var(--space-3);
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-sm);
}

.ai-suggestion-header {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-3);
}

.ai-suggestion-icon {
  font-size: 32rpx;
}

.ai-suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

.ai-suggestion-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.ai-sort-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  background: var(--surface);
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border);
  transition: all 0.2s ease;
  margin-top: var(--space-3);
}

.ai-sort-toggle.active {
  background: var(--primary-subtle);
  border-color: var(--primary);
}

.ai-sort-icon {
  font-size: 28rpx;
}

.ai-sort-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.ai-sort-toggle.active .ai-sort-text {
  color: var(--primary);
  font-weight: 600;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
  position: relative;
}

.stat-item + .stat-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 1rpx;
  background: var(--border);
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-number.pending {
  color: var(--primary);
}

.stat-number.completed {
  color: var(--success);
}

.stat-number.total {
  color: var(--text);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

.quick-add-section {
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: var(--space-5);
  border: 1rpx solid var(--border);
}

.quick-add-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 14rpx 20rpx;
  border: 1rpx solid var(--border);
}

.quick-plus {
  font-size: 32rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.quick-input {
  flex: 1;
  height: 48rpx;
  background: transparent;
  border: none;
  color: var(--text);
  font-size: 28rpx;
}

.quick-input::placeholder {
  color: var(--text-tertiary);
}

.quick-add-btn {
  padding: 16rpx 28rpx;
  border-radius: var(--radius-sm);
  background: var(--border);
  color: var(--text-tertiary);
  font-size: 26rpx;
  font-weight: 600;
}

.quick-add-btn.active {
  background: var(--primary);
  color: var(--text-inverse);
}

.quick-category-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.quick-category-item {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--bg);
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid var(--border);
}

.quick-category-item.active {
  background: var(--primary-subtle);
  color: var(--primary);
  border-color: var(--primary);
}

.category-section {
  margin-bottom: var(--space-5);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-scroll {
  flex: 1;
  white-space: nowrap;
}

.category-action-btn {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: var(--radius-full);
  background: var(--error-subtle);
  border: 1rpx solid var(--error);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.category-action-btn:active {
  opacity: 0.7;
  transform: scale(0.92);
}

.category-action-btn text {
  font-size: 24rpx;
}

.category-action-text {
  color: var(--error);
  font-size: 24rpx;
  font-weight: 500;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: var(--radius-full);
  background: var(--surface);
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid var(--border);
  white-space: nowrap;
  flex-shrink: 0;
}

.category-item.active {
  background: var(--primary);
  color: var(--text-inverse);
  border-color: var(--primary);
}

.category-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-scroll {
  flex: 1;
}

.delete-completed-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  border-radius: var(--radius-full);
  background: var(--surface);
  color: var(--danger, #ff4d4f);
  font-size: 26rpx;
  font-weight: 500;
  border: 1rpx solid var(--danger, #ff4d4f);
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.delete-completed-btn:active {
  opacity: 0.7;
  transform: scale(0.96);
}

.delete-completed-icon {
  font-size: 24rpx;
}

.delete-completed-text {
  font-size: 24rpx;
}

.todos-list {
  padding-bottom: 120rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--border);
  box-shadow: var(--shadow-xs);
  animation: fadeInUp 0.3s ease-out backwards;
}

.todo-item.pinned {
  border-left: 4rpx solid var(--primary);
}

.todo-item.completed {
  opacity: 0.56;
}

.todo-check {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--text-tertiary);
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.check-circle.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.check-circle text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.todo-content {
  flex: 1;
  min-width: 0;
}

.todo-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.todo-title {
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.4;
  font-weight: 500;
}

.todo-item.completed .todo-title {
  text-decoration: line-through;
  color: var(--text-tertiary);
}

.todo-category-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: var(--primary-subtle);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.todo-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.action-btn text {
  font-size: 24rpx;
}

.pin-btn.active {
  background: var(--primary-subtle);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 30rpx;
  color: var(--text-tertiary);
}
